{
  "name": "openrouter-cli-v2",
  "version": "1.3.6",
  "description": "The AI coding CLI powered by OpenRouter.",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vincyxiroff/openrouter-cli.git"
  },
  "bugs": {
    "url": "https://github.com/vincyxiroff/openrouter-cli/issues"
  },
  "homepage": "https://github.com/vincyxiroff/openrouter-cli#readme",
  "bin": {
    "orc": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepack": "npm run build",
    "version:patch": "npm version patch",
    "version:minor": "npm version minor",
    "version:major": "npm version major",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "husky"
  },
  "keywords": [
    "openrouter",
    "cli",
    "ai",
    "coding-agent",
    "terminal"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@inquirer/prompts": "^7.4.1",
    "boxen": "^8.0.1",
    "chalk": "^5.4.1",
    "cli-highlight": "^2.1.11",
    "commander": "^13.1.0",
    "diff": "^9.0.0",
    "dotenv": "^16.4.7",
    "execa": "^9.5.2",
    "ignore": "^7.0.3",
    "markdown-it": "^14.1.0",
    "ora": "^8.2.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.7.1",
    "@commitlint/config-conventional": "^19.7.1",
    "@eslint/js": "^9.21.0",
    "@types/diff": "^7.0.1",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^22.13.10",
    "eslint": "^9.21.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3",
    "prettier": "^3.5.3",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.26.1",
    "vitest": "^3.0.8"
  },
  "lint-staged": {
    "*.{ts,js,json,md,yml,yaml}": [
      "prettier --write"
    ],
    "src/**/*.ts": [
      "eslint --fix"
    ]
  }
}
