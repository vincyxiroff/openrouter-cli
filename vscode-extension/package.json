{
  "name": "openrouter-cli-vscode",
  "displayName": "OpenRouter CLI",
  "description": "A polished VS Code control center for OpenRouter CLI chat, edits, trust, setup, and diagnostics.",
  "version": "0.2.0",
  "publisher": "openrouter-cli",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/vincyxiroff/openrouter-cli"
  },
  "engines": {
    "vscode": "^1.92.0"
  },
  "categories": [
    "AI",
    "Other"
  ],
  "keywords": [
    "openrouter",
    "ai",
    "coding-agent",
    "chat",
    "code-editing",
    "cli"
  ],
  "activationEvents": [
    "onCommand:openrouterCli.chat",
    "onCommand:openrouterCli.explain",
    "onCommand:openrouterCli.edit",
    "onCommand:openrouterCli.fixErrors",
    "onCommand:openrouterCli.refactor",
    "onCommand:openrouterCli.addDocumentation",
    "onCommand:openrouterCli.trustStatus",
    "onCommand:openrouterCli.trustProject",
    "onCommand:openrouterCli.trustFolder",
    "onCommand:openrouterCli.removeTrust",
    "onCommand:openrouterCli.openTerminal",
    "onView:openrouterCli.chatView"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "openrouterCli.chat",
        "title": "OpenRouter CLI: Chat"
      },
      {
        "command": "openrouterCli.explain",
        "title": "OpenRouter CLI: Explain"
      },
      {
        "command": "openrouterCli.edit",
        "title": "OpenRouter CLI: Edit"
      },
      {
        "command": "openrouterCli.fixErrors",
        "title": "OpenRouter CLI: Fix Errors"
      },
      {
        "command": "openrouterCli.refactor",
        "title": "OpenRouter CLI: Refactor"
      },
      {
        "command": "openrouterCli.addDocumentation",
        "title": "OpenRouter CLI: Add Documentation"
      },
      {
        "command": "openrouterCli.trustStatus",
        "title": "OpenRouter CLI: Trust Status"
      },
      {
        "command": "openrouterCli.trustProject",
        "title": "OpenRouter CLI: Trust Project"
      },
      {
        "command": "openrouterCli.trustFolder",
        "title": "OpenRouter CLI: Trust Folder"
      },
      {
        "command": "openrouterCli.removeTrust",
        "title": "OpenRouter CLI: Remove Trust"
      },
      {
        "command": "openrouterCli.openTerminal",
        "title": "OpenRouter CLI: Open Terminal"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "openrouterCli.explain",
          "when": "editorHasSelection",
          "group": "openrouter"
        },
        {
          "command": "openrouterCli.fixErrors",
          "when": "editorHasSelection",
          "group": "openrouter"
        },
        {
          "command": "openrouterCli.refactor",
          "when": "editorHasSelection",
          "group": "openrouter"
        },
        {
          "command": "openrouterCli.addDocumentation",
          "when": "editorHasSelection",
          "group": "openrouter"
        }
      ],
      "commandPalette": [
        {
          "command": "openrouterCli.trustStatus",
          "group": "openrouter"
        },
        {
          "command": "openrouterCli.trustProject",
          "group": "openrouter"
        },
        {
          "command": "openrouterCli.trustFolder",
          "group": "openrouter"
        },
        {
          "command": "openrouterCli.removeTrust",
          "group": "openrouter"
        },
        {
          "command": "openrouterCli.openTerminal",
          "group": "openrouter"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "openrouterCli",
          "title": "OpenRouter CLI",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "openrouterCli": [
        {
          "type": "webview",
          "id": "openrouterCli.chatView",
          "name": "Chat"
        }
      ]
    },
    "configuration": {
      "title": "OpenRouter CLI",
      "properties": {
        "openrouterCli.command": {
          "type": "string",
          "default": "orc",
          "description": "Command used to run OpenRouter CLI."
        }
      }
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "package:vsix": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/vscode": "^1.92.0",
    "@vscode/vsce": "^3.9.1",
    "typescript": "^5.8.2"
  }
}
